{
  "Da": {
    "ProgId": "Matrikon.OPC.Simulation.1",
    "Host": "localhost",
    "UpdateRateMs": 1000,
    "UseSubscriptions": true
  },
  "Ua": {
    "ApplicationName": "OpcDaToUaBridge",
    "EndpointUrl": "opc.tcp://0.0.0.0:4840/OpcBridge",
    "AutoAcceptUntrustedCertificates": true,
    "RequireAuthentication": false,
    "Username": "",
    "Password": "",
    "AllowedIpAddresses": []
  },
  "Bridge": {
    "RateLimits": {
      "100": 200,
      "250": 500,
      "500": 1000,
      "1000": 5000,
      "2000": 10000,
      "5000": 20000,
      "10000": 50000
    },
    "ExpectedTagCount": 1000,
    "Mappings": [
      {
        "DaItemId": "Random.Int1",
        "UaNodeId": "ns=2;s=Random.Int1",
        "DisplayName": "Random Int1",
        "DataType": "Int32"
      },
      {
        "DaItemId": "Random.Real8",
        "UaNodeId": "ns=2;s=Random.Real8",
        "DisplayName": "Random Real8",
        "DataType": "Double"
      },
      {
        "DaItemId": "Random.Boolean",
        "UaNodeId": "ns=2;s=Random.Boolean",
        "DisplayName": "Random Boolean",
        "DataType": "Boolean"
      }
    ]
  },
  "Mqtt": {
    "Enabled": false,
    "BrokerUrl": "tcp://localhost:1883",
    "ClientId": "OpcDaToUaBridge",
    "UserName": null,
    "Password": null,
    "Tls": false,
    "IgnoreCertErrors": false,
    "TopicPrefix": "bridge/tags",
    "PayloadFields": "Value, Timestamp"
  }
}
