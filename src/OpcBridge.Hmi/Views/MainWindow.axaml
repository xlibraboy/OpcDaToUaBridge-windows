<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:OpcBridge.Hmi.ViewModels"
        x:Class="OpcBridge.Hmi.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="OpcBridge HMI"
        Width="1100"
        Height="700">
  <DockPanel Margin="12">
    <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto,Auto,Auto" Margin="0,0,0,8">
      <TextBox Grid.Column="0"
               Watermark="Base URL"
               Text="{Binding BaseUrl}"
               Margin="0,0,8,0" />
      <Button Grid.Column="1"
              Content="Connect"
              Command="{Binding ConnectCommand}"
              Margin="0,0,8,0"
              MinWidth="96" />
      <Button Grid.Column="2"
              Content="Disconnect"
              Command="{Binding DisconnectCommand}"
              Margin="0,0,8,0"
              MinWidth="96" />
      <TextBlock Grid.Column="3"
                 VerticalAlignment="Center"
                 Text="{Binding ConnectionState, StringFormat=Status: {0}}" />
    </Grid>

    <StackPanel DockPanel.Dock="Top"
                Orientation="Horizontal"
                Spacing="8"
                Margin="0,0,0,8">
      <TextBlock VerticalAlignment="Center" Text="Filter:" />
      <TextBox Width="320"
               Watermark="Source, name, or value"
               Text="{Binding Filter}" />
    </StackPanel>

    <Grid ColumnDefinitions="2*,*" >
      <Border Grid.Column="0"
              BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
              BorderThickness="1"
              CornerRadius="4"
              Padding="8"
              Margin="0,0,12,0">
        <DockPanel>
          <Grid DockPanel.Dock="Top"
                ColumnDefinitions="*,2*,*,*"
                Margin="4,0,4,6">
            <TextBlock Grid.Column="0" FontWeight="SemiBold" Text="Source" />
            <TextBlock Grid.Column="1" FontWeight="SemiBold" Text="Name" />
            <TextBlock Grid.Column="2" FontWeight="SemiBold" Text="Value" />
            <TextBlock Grid.Column="3" FontWeight="SemiBold" Text="Q" />
          </Grid>
          <ListBox ItemsSource="{Binding FilteredTags}"
                   SelectedItem="{Binding SelectedTag}">
            <ListBox.ItemTemplate>
              <DataTemplate x:DataType="vm:TagItemViewModel">
                <Grid ColumnDefinitions="*,2*,*,*">
                  <TextBlock Grid.Column="0" Text="{Binding SourceId}" TextTrimming="CharacterEllipsis" />
                  <TextBlock Grid.Column="1" Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis" />
                  <TextBlock Grid.Column="2" Text="{Binding ValueText}" TextTrimming="CharacterEllipsis" />
                  <TextBlock Grid.Column="3" Text="{Binding QualityText}" TextTrimming="CharacterEllipsis" />
                </Grid>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </DockPanel>
      </Border>

      <Border Grid.Column="1"
              BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
              BorderThickness="1"
              CornerRadius="4"
              Padding="12">
        <StackPanel Spacing="8">
          <TextBlock FontSize="16" FontWeight="SemiBold" Text="Faceplate" />
          <TextBlock Text="{Binding SelectedTag.DisplayName, StringFormat=Name: {0}}" />
          <TextBlock Text="{Binding SelectedTag.DaItemId, StringFormat=Item: {0}}" />
          <TextBlock Text="{Binding SelectedTag.DataType, StringFormat=Type: {0}}" />
          <TextBlock Text="{Binding SelectedTag.ValueText, StringFormat=Value: {0}}" />
          <TextBlock Text="{Binding SelectedTag.QualityText, StringFormat=Quality: {0}}" />
          <TextBlock Text="{Binding SelectedTag.TimestampText, StringFormat=Timestamp: {0}}" />
          <StackPanel Orientation="Horizontal"
                      Spacing="8"
                      IsEnabled="{Binding SelectedTag.Writeable, FallbackValue=False, TargetNullValue=False}">
            <TextBlock VerticalAlignment="Center" Text="Write:" />
            <TextBox Width="160" Text="{Binding WriteValue}" />
            <Button Content="Write" Command="{Binding WriteCommand}" MinWidth="80" />
          </StackPanel>
          <TextBlock Text="{Binding StatusMessage}"
                     TextWrapping="Wrap"
                     Opacity="0.85" />
        </StackPanel>
      </Border>
    </Grid>
  </DockPanel>
</Window>
